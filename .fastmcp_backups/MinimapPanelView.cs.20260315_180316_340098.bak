        private static Vector2 ResolveAccentSizeForCard(Vector2 baseAccentSize, float cardHeight)
        {
            return new Vector2(baseAccentSize.x, cardHeight);
        }

        private int ResolveRoomStatusEyebrowFontSize()
        {
            ChallengeBannerLayoutProfile layoutProfile = ResolveCurrentChallengeLayoutProfile();
            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineStatusEyebrowFontSize,
                ChallengeBannerLayoutProfile.Pace => challengePaceStatusEyebrowFontSize,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningStatusEyebrowFontSize,
                _ => roomStatusEyebrowFontSize
            };
        }

