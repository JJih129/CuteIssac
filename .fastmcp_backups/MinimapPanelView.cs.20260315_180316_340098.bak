            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineDetailEyebrowFontSize,
                ChallengeBannerLayoutProfile.Pace => challengePaceDetailEyebrowFontSize,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningDetailEyebrowFontSize,
