        private static RectTransform CreateViewportRoot(RectTransform parent)
        {
            GameObject viewportObject = new("ViewportRoot", typeof(RectTransform));
            viewportObject.layer = parent.gameObject.layer;
            RectTransform viewportRect = viewportObject.GetComponent<RectTransform>();
            viewportRect.SetParent(parent, false);
            viewportRect.anchorMin = Vector2.zero;
            viewportRect.anchorMax = Vector2.one;
            viewportRect.offsetMin = Vector2.zero;
            viewportRect.offsetMax = Vector2.zero;
            return viewportRect;
        }

        private void ReparentViewportChild(RectTransform child)
        {
            if (child == null || viewportRoot == null || child == viewportRoot)
            {
                return;
            }

            if (child.parent != viewportRoot)
            {
                child.SetParent(viewportRoot, false);
            }
        }

        private void ApplyStatusCardVisibility(bool showStatusCard, bool showDetailCard)
        {
            if (roomStatusCardImage != null)
            {
                roomStatusCardImage.gameObject.SetActive(showStatusCard);
            }

            if (roomStatusAccentImage != null)
            {
                roomStatusAccentImage.gameObject.SetActive(showStatusCard);
            }

            if (roomDetailCardImage != null)
            {
                roomDetailCardImage.gameObject.SetActive(showDetailCard);
            }

            if (roomDetailAccentImage != null)
            {
                roomDetailAccentImage.gameObject.SetActive(showDetailCard);
            }
        }

        private void ApplyStatusLayout(bool compactMode)
        {
            ChallengeBannerLayoutProfile layoutProfile = ResolveCurrentChallengeLayoutProfile();
            Vector2 resolvedStatusCardSize = ResolveRoomStatusCardSize(layoutProfile, compactMode);
            Vector2 resolvedStatusTextSize = ResolveRoomStatusTextSize(layoutProfile, compactMode);
            resolvedStatusTextSize = new Vector2(
                Mathf.Max(24f, resolvedStatusTextSize.x - ResolveRoomStatusTextWidthTrim(layoutProfile, compactMode)),
                resolvedStatusTextSize.y);
            Vector2 resolvedStatusAccentSize = ResolveAccentSizeForCard(compactMode ? compactRoomStatusAccentSize : roomStatusAccentSize, resolvedStatusCardSize.y);
            float statusHeightDelta = compactMode
                ? resolvedStatusCardSize.y - compactRoomStatusCardSize.y
                : resolvedStatusCardSize.y - roomStatusCardSize.y;
            Vector2 expandedStatusTextPosition = roomStatusTextPosition + new Vector2(ResolveRoomStatusContentShiftX(layoutProfile, false), 0f);
            Vector2 compactStatusTextPosition = compactRoomStatusTextPosition + new Vector2(ResolveRoomStatusContentShiftX(layoutProfile, true), 0f);

            Vector2 detailCardPosition = roomDetailCardPosition + new Vector2(0f, -Mathf.Max(0f, statusHeightDelta * 0.7f));
            Vector2 detailAccentPosition = roomDetailAccentPosition + new Vector2(0f, -Mathf.Max(0f, statusHeightDelta * 0.7f));
            Vector2 detailTextPosition = roomDetailTextPosition
                + new Vector2(ResolveRoomDetailContentShiftX(layoutProfile), -Mathf.Max(0f, statusHeightDelta * 0.7f));
            Vector2 resolvedDetailCardSize = ResolveRoomDetailCardSize(layoutProfile);
            Vector2 resolvedDetailTextSize = ResolveRoomDetailTextSize(layoutProfile);
            resolvedDetailTextSize = new Vector2(
                Mathf.Max(36f, resolvedDetailTextSize.x - ResolveRoomDetailTextWidthTrim(layoutProfile)),
                resolvedDetailTextSize.y);
            Vector2 resolvedDetailAccentSize = ResolveAccentSizeForCard(roomDetailAccentSize, resolvedDetailCardSize.y);

            ApplyStatusElementLayout(roomTypeBadgeImage, roomTypeBadgePosition, roomTypeBadgeSize, compactRoomTypeBadgePosition, compactRoomTypeBadgeSize, compactMode, false);
            ApplyStatusElementLayout(roomTypeIconImage, roomTypeIconPosition, roomTypeIconSize, compactRoomTypeIconPosition, compactRoomTypeIconSize, compactMode, false);
            ApplyStatusElementLayout(roomTypeLabelText, roomTypeLabelPosition, roomTypeLabelSize, compactRoomTypeLabelPosition, compactRoomTypeLabelSize, compactMode, false);
            ApplyStatusElementLayout(roomStatusCardImage, roomStatusCardPosition, resolvedStatusCardSize, compactRoomStatusCardPosition, resolvedStatusCardSize, compactMode, true);
            ApplyStatusElementLayout(roomStatusAccentImage, roomStatusAccentPosition, resolvedStatusAccentSize, compactRoomStatusAccentPosition, resolvedStatusAccentSize, compactMode, true);
            ApplyStatusElementLayout(roomStatusText, expandedStatusTextPosition, resolvedStatusTextSize, compactStatusTextPosition, resolvedStatusTextSize, compactMode, true);
            ApplyStatusElementLayout(roomDetailCardImage, detailCardPosition, resolvedDetailCardSize, detailCardPosition, resolvedDetailCardSize, compactMode, true);
            ApplyStatusElementLayout(roomDetailAccentImage, detailAccentPosition, resolvedDetailAccentSize, detailAccentPosition, resolvedDetailAccentSize, compactMode, true);
            ApplyStatusElementLayout(roomDetailText, detailTextPosition, resolvedDetailTextSize, detailTextPosition, resolvedDetailTextSize, compactMode, true);

            if (roomStatusText != null)
            {
                roomStatusText.alignment = compactMode ? TextAnchor.MiddleLeft : TextAnchor.UpperLeft;
                roomStatusText.fontSize = compactMode ? compactRoomStatusFontSize : roomStatusFontSize;
                roomStatusText.supportRichText = true;
                roomStatusText.lineSpacing = ResolveRoomStatusLineSpacing();
                roomStatusText.horizontalOverflow = compactMode ? HorizontalWrapMode.Overflow : HorizontalWrapMode.Wrap;
                roomStatusText.verticalOverflow = compactMode ? VerticalWrapMode.Truncate : VerticalWrapMode.Overflow;
                roomStatusText.alignByGeometry = true;
            }

            if (roomDetailText != null)
            {
                roomDetailText.alignment = TextAnchor.UpperLeft;
                roomDetailText.fontSize = roomDetailFontSize;
                roomDetailText.supportRichText = true;
                roomDetailText.lineSpacing = ResolveRoomDetailLineSpacing();
                roomDetailText.horizontalOverflow = HorizontalWrapMode.Wrap;
                roomDetailText.verticalOverflow = VerticalWrapMode.Overflow;
                roomDetailText.alignByGeometry = true;
            }

            if (roomTypeLabelText != null)
            {
                roomTypeLabelText.alignment = TextAnchor.MiddleLeft;
                roomTypeLabelText.fontSize = compactMode ? compactRoomTypeFontSize : roomTypeFontSize;
                roomTypeLabelText.supportRichText = true;
            }
        }

        private static void ApplyStatusElementLayout(
            Graphic graphic,
            Vector2 anchoredPosition,
            Vector2 size,
            Vector2 compactAnchoredPosition,
            Vector2 compactSize,
            bool compactMode,
            bool hideInCompact)
        {
            if (graphic == null)
            {
                return;
            }

            RectTransform rectTransform = graphic.rectTransform;
            rectTransform.anchorMin = new Vector2(0f, 1f);
            rectTransform.anchorMax = new Vector2(0f, 1f);
            rectTransform.pivot = new Vector2(0f, 1f);
            rectTransform.anchoredPosition = compactMode ? compactAnchoredPosition : anchoredPosition;
            rectTransform.sizeDelta = compactMode ? compactSize : size;

            if (compactMode && hideInCompact)
            {
                graphic.gameObject.SetActive(false);
            }
        }

        private void ApplyRoomTypeBadge(RoomType roomType, Color accentColor, bool visible)
        {
            bool hideBadgeForTopBar = (_topBarLayoutActive && hideRoomTypeBadgeInTopBar)
                || ShouldSuppressCompactChallengeAuxiliaryCopy();
            Sprite badgeIcon = GetSpecialIcon(roomType, RoomExplorationState.Visited);
            string label = ResolveRoomTypeBadgeLabel(roomType);
            bool showBadge = !hideBadgeForTopBar && visible && (!string.IsNullOrWhiteSpace(label) || badgeIcon != null);
            ApplyDynamicBadgeLayout(label, badgeIcon != null);
            Color badgeBackgroundColor = ResolveUnifiedRoomTypeBadgeBackgroundColor(roomType, accentColor);
            Color badgeIconColor = ResolveUnifiedRoomTypeBadgeIconColor(roomType, accentColor);

            if (roomTypeBadgeImage != null)
            {
                roomTypeBadgeImage.gameObject.SetActive(showBadge);
                roomTypeBadgeImage.color = badgeBackgroundColor;
            }

            if (roomTypeIconImage != null)
            {
                roomTypeIconImage.gameObject.SetActive(showBadge && badgeIcon != null);

                if (showBadge && badgeIcon != null)
                {
                    roomTypeIconImage.sprite = badgeIcon;
                    roomTypeIconImage.color = badgeIconColor;
                }
            }

            if (roomTypeLabelText != null)
            {
                roomTypeLabelText.gameObject.SetActive(showBadge);
                int fontSize = _compactMode ? compactRoomTypeFontSize : roomTypeFontSize;
                roomTypeLabelText.text = $"<size={fontSize}><b>{label}</b></size>";
                roomTypeLabelText.color = ResolveUnifiedRoomTypeBadgeLabelColor(roomType);
            }
        }

        private void CacheStatusVisualBaseline(Color accentColor)
        {
            _statusEmphasisAccentColor = accentColor;
            _baseRoomTypeBadgeColor = roomTypeBadgeImage != null ? roomTypeBadgeImage.color : roomTypeBadgeBaseColor;
            _baseRoomStatusCardColor = roomStatusCardImage != null ? roomStatusCardImage.color : roomStatusCardColor;
            _baseRoomDetailCardColor = roomDetailCardImage != null ? roomDetailCardImage.color : roomDetailCardColor;
            _baseRoomStatusAccentColor = roomStatusAccentImage != null ? roomStatusAccentImage.color : new Color(accentColor.r, accentColor.g, accentColor.b, accentRailOpacity);
            _baseRoomDetailAccentColor = roomDetailAccentImage != null ? roomDetailAccentImage.color : new Color(accentColor.r, accentColor.g, accentColor.b, accentRailOpacity * 0.8f);
            _baseRoomStatusTextColor = roomStatusText != null ? roomStatusText.color : accentColor;
            _baseRoomDetailTextColor = roomDetailText != null ? roomDetailText.color : roomDetailColor;
            _baseRoomTypeIconColor = roomTypeIconImage != null ? roomTypeIconImage.color : accentColor;

            if (roomStatusAccentImage != null)
            {
                roomStatusAccentImage.color = _baseRoomStatusAccentColor;
            }

            if (roomDetailAccentImage != null)
            {
                roomDetailAccentImage.color = _baseRoomDetailAccentColor;
            }
        }

        private bool ShouldUseCurseAltarReadyTheme(RoomType roomType, string headline)
        {
            return roomType == RoomType.Curse
                && !string.IsNullOrWhiteSpace(headline)
                && (headline.Contains("제단 개방") || headline.Contains("대가 개방"));
        }

        private bool ShouldUseChallengeThreatTheme(RoomType roomType)
        {
            return roomType == RoomType.Challenge && _hasChallengeThreatStatusTheme;
        }

        private bool UsesChallengeBaselineTheme()
        {
            return _hasChallengeThreatStatusTheme && string.Equals(_challengeThreatBadgeLabel, "챌린지");
        }

        private Color ResolveChallengeThreatThemeAccent()
        {
            if (_hasChallengeThreatStatusTheme)
            {
                return _challengeThreatStatusAccentColor;
            }

            ChallengeThreatPresentation presentation = ChallengeThreatPresentationResolver.Build(
                Mathf.Max(1, _challengeThreatWaveNumber),
                1,
                0,
                _challengeThreatGuaranteedChampionCount,
                _challengeThreatChampionChanceBonus);
            return presentation.AccentColor;
        }

        private Color ResolveStatusEyebrowColor(bool useChallengeThreatTheme)
        {
            if (!useChallengeThreatTheme && TryResolveExplicitChallengeBadgeLabelColor(out Color explicitLabelColor))
            {
                return explicitLabelColor;
            }

            if (!useChallengeThreatTheme)
            {
                return roomStatusLabelColor;
            }

            float themeStrength = ChallengeThreatPresentationResolver.ResolveStatusThemeStrength(_challengeThreatStage);
            float blend = Mathf.Clamp01(0.22f + (challengeThreatEyebrowBoost * themeStrength));
            return Color.Lerp(roomStatusLabelColor, challengeThreatEyebrowColor, blend);
        }

        private Color ResolveDetailEyebrowColor(bool useChallengeThreatTheme)
        {
            if (!useChallengeThreatTheme && TryResolveExplicitChallengeBadgeLabelColor(out Color explicitLabelColor))
            {
                return Color.Lerp(explicitLabelColor, Color.white, 0.12f);
            }

            if (!useChallengeThreatTheme)
            {
                return roomStatusLabelColor;
            }

            float themeStrength = ChallengeThreatPresentationResolver.ResolveStatusThemeStrength(_challengeThreatStage);
            float blend = Mathf.Clamp01(0.18f + (challengeThreatEyebrowBoost * 0.8f * themeStrength));
            return Color.Lerp(roomStatusLabelColor, Color.Lerp(challengeThreatEyebrowColor, Color.white, 0.1f), blend);
        }

        private Color ResolveCompactChallengeThreatTagColor()
        {
            float themeStrength = ChallengeThreatPresentationResolver.ResolveStatusThemeStrength(_challengeThreatStage);
            float blend = Mathf.Clamp01(0.26f + (challengeThreatEyebrowBoost * themeStrength));
            return Color.Lerp(
                Color.Lerp(_currentAccentColor, Color.white, 0.22f),
                challengeThreatCompactTagColor,
                blend);
        }

        private void ApplySpecialStatusTheme(RoomType roomType, bool useCurseAlertTheme, bool useCurseAltarReadyTheme, bool useChallengeThreatTheme)
        {
            Color challengeThemeAccent = ResolveChallengeThreatThemeAccent();
            float challengeThemeStrength = ChallengeThreatPresentationResolver.ResolveStatusThemeStrength(_challengeThreatStage);
            float badgeBlend = Mathf.Clamp01(0.46f * challengeThemeStrength);
            float statusBlend = Mathf.Clamp01(0.26f * challengeThemeStrength);
            float detailBlend = Mathf.Clamp01(0.18f * challengeThemeStrength);
            float detailTextBlend = Mathf.Clamp01(0.18f * challengeThemeStrength);

            if (roomTypeBadgeImage != null)
            {
                roomTypeBadgeImage.color = useCurseAlertTheme
                    ? curseAlertBadgeColor
                    : useCurseAltarReadyTheme
                        ? curseAltarReadyBadgeColor
                        : useChallengeThreatTheme
                            ? ResolveChallengeThemeBadgeColor(challengeThemeAccent, badgeBlend)
                        : roomTypeBadgeImage.color;
            }

            if (roomStatusCardImage != null)
            {
                roomStatusCardImage.color = useCurseAlertTheme
                    ? curseAlertStatusCardColor
                    : useCurseAltarReadyTheme
                        ? curseAltarReadyStatusCardColor
                        : useChallengeThreatTheme
                            ? ResolveChallengeThemeStatusCardColor(challengeThemeAccent, statusBlend)
                        : roomStatusCardColor;
            }

            if (roomDetailCardImage != null)
            {
                roomDetailCardImage.color = useCurseAlertTheme
                    ? curseAlertDetailCardColor
                    : useCurseAltarReadyTheme
                        ? curseAltarReadyDetailCardColor
                        : useChallengeThreatTheme
                            ? ResolveChallengeThemeDetailCardColor(challengeThemeAccent, detailBlend)
                        : roomDetailCardColor;
            }

            if (roomDetailText != null)
            {
                roomDetailText.color = useCurseAlertTheme
                    ? curseAlertDetailTextColor
                    : useCurseAltarReadyTheme
                        ? curseAltarReadyDetailTextColor
                        : useChallengeThreatTheme
                            ? ResolveChallengeThemeDetailTextColor(challengeThemeAccent, detailTextBlend)
                            : roomDetailColor;
            }

            if (useChallengeThreatTheme)
            {
                if (roomStatusAccentImage != null)
                {
                    float railBlend = Mathf.Clamp01(0.32f + (challengeThreatAccentRailBoost * challengeThemeStrength));
                    roomStatusAccentImage.color = Color.Lerp(
                        new Color(challengeThemeAccent.r, challengeThemeAccent.g, challengeThemeAccent.b, accentRailOpacity),
                        Color.Lerp(challengeThemeAccent, Color.white, 0.18f),
                        railBlend);
                }

                if (roomDetailAccentImage != null)
                {
                    float railBlend = Mathf.Clamp01(0.18f + (challengeThreatAccentRailBoost * 0.82f * challengeThemeStrength));
                    roomDetailAccentImage.color = Color.Lerp(
                        new Color(challengeThemeAccent.r, challengeThemeAccent.g, challengeThemeAccent.b, accentRailOpacity * 0.86f),
                        Color.Lerp(challengeThemeAccent, Color.white, 0.12f),
                        railBlend);
                }
            }
        }

        private string ResolveRoomTypeBadgeLabel(RoomType roomType)
        {
            if (!string.IsNullOrWhiteSpace(_explicitRoomStatusBadgeLabel))
            {
                return _explicitRoomStatusBadgeLabel;
            }

            if (ShouldUseChallengeThreatTheme(roomType) && !string.IsNullOrWhiteSpace(_challengeThreatBadgeLabel))
            {
                return _challengeThreatBadgeLabel;
            }

            return GetRoomTypeLabel(roomType);
        }

        private Color ResolveUnifiedRoomTypeBadgeBackgroundColor(RoomType roomType, Color accentColor)
        {
            if (TryResolveExplicitChallengeBadgeBackgroundColor(out Color explicitBadgeColor))
            {
                return explicitBadgeColor;
            }

            return Color.Lerp(roomTypeBadgeBaseColor, accentColor, 0.22f);
        }

        private Color ResolveUnifiedRoomTypeBadgeIconColor(RoomType roomType, Color accentColor)
        {
            if (TryResolveExplicitChallengeBadgeLabelColor(out Color explicitLabelColor))
            {
                return explicitLabelColor;
            }

            return ShouldUseChallengeThreatTheme(roomType)
                ? ResolveUnifiedRoomTypeBadgeLabelColor(roomType)
                : accentColor;
        }

        private Color ResolveUnifiedRoomTypeBadgeLabelColor(RoomType roomType)
        {
            if (TryResolveExplicitChallengeBadgeLabelColor(out Color explicitLabelColor))
            {
                return explicitLabelColor;
            }

            if (!ShouldUseChallengeThreatTheme(roomType))
            {
                return roomTypeLabelColor;
            }

            Color baseLabelColor = IsChallengeBaselineBadgeLabel(_challengeThreatBadgeLabel)
                ? challengeBaselineLabelColor
                : roomTypeLabelColor;
            Color accentTarget = Color.Lerp(ResolveChallengeThreatThemeAccent(), Color.white, 0.3f);
            float themeStrength = ChallengeThreatPresentationResolver.ResolveStatusThemeStrength(_challengeThreatStage);
            float blend = Mathf.Clamp01(0.12f + (0.16f * themeStrength));
            return Color.Lerp(baseLabelColor, accentTarget, blend);
        }

        private bool TryResolveExplicitChallengeBadgeBackgroundColor(out Color color)
        {
            if (IsChallengeRewardReadyStatus())
            {
                color = IsChallengeFinaleStatus()
                    ? challengeFinaleBadgeColor
                    : challengeRewardReadyBadgeColor;
                return true;
            }

            if (IsChallengeCompletedStatus())
            {
                color = IsChallengeFinaleStatus()
                    ? challengeFinaleBadgeColor
                    : challengeCompletedBadgeColor;
                return true;
            }

            color = default;
            return false;
        }

        private bool TryResolveExplicitChallengeBadgeLabelColor(out Color color)
        {
            if (IsChallengeRewardReadyStatus())
            {
                color = IsChallengeFinaleStatus()
                    ? challengeFinaleLabelColor
                    : challengeRewardReadyLabelColor;
                return true;
            }

            if (IsChallengeCompletedStatus())
            {
                color = IsChallengeFinaleStatus()
                    ? challengeFinaleLabelColor
                    : challengeCompletedLabelColor;
                return true;
            }

            if (IsChallengeBaselineBadgeLabel(_explicitRoomStatusBadgeLabel))
            {
                color = challengeBaselineLabelColor;
                return true;
            }

            color = default;
            return false;
        }

        private bool IsChallengeRewardReadyStatus()
        {
            return _currentRoomType == RoomType.Challenge
                && IsChallengeRewardReadyBadgeLabel(_explicitRoomStatusBadgeLabel);
        }

        private bool IsChallengeCompletedStatus()
        {
            return _currentRoomType == RoomType.Challenge
                && IsChallengeCompletedBadgeLabel(_explicitRoomStatusBadgeLabel);
        }

        private bool IsChallengeFinaleStatus()
        {
            return _currentRoomType == RoomType.Challenge
                && !string.IsNullOrWhiteSpace(_currentHeadline)
                && (_currentHeadline.Contains("\uC644\uC804 \uC81C\uC555")
                    || _currentHeadline.Contains("\uCD5C\uC885"));
        }

        private bool ShouldSuppressCompactChallengeAuxiliaryCopy()
        {
            return _compactMode
                && _topBarLayoutActive
                && _currentRoomType == RoomType.Challenge
                && !string.IsNullOrWhiteSpace(_explicitRoomStatusCompactTag);
        }

        private static bool IsChallengeBaselineBadgeLabel(string label)
        {
            return string.Equals(CollapseWhitespace(label), "\uCC4C\uB9B0\uC9C0", System.StringComparison.Ordinal);
        }

        private static bool IsChallengeRewardReadyBadgeLabel(string label)
        {
            return string.Equals(CollapseWhitespace(label), "\uB3C4\uC804 \uBCF4\uC0C1", System.StringComparison.Ordinal);
        }

        private static bool IsChallengeCompletedBadgeLabel(string label)
        {
            return string.Equals(CollapseWhitespace(label), "\uB3C4\uC804 \uC644\uB8CC", System.StringComparison.Ordinal);
        }

        private Color ResolveRoomTypeBadgeLabelColor(RoomType roomType)
        {
            return ResolveUnifiedRoomTypeBadgeLabelColor(roomType);
        }

                if (string.Equals(_explicitRoomStatusBadgeLabel, "도전 페이스"))
                {
                    return Color.Lerp(challengeBaselineLabelColor, Color.white, 0.08f);
                }

                if (string.Equals(_explicitRoomStatusBadgeLabel, "엘리트 경보"))
                {
                    Color explicitAccentTarget = Color.Lerp(ResolveChallengeThreatThemeAccent(), Color.white, 0.3f);
                    float explicitThemeStrength = ChallengeThreatPresentationResolver.ResolveStatusThemeStrength(_challengeThreatStage);
                    float explicitBlend = Mathf.Clamp01(0.12f + (0.16f * explicitThemeStrength));
                    return Color.Lerp(roomTypeLabelColor, explicitAccentTarget, explicitBlend);
                }
            }

            if (!ShouldUseChallengeThreatTheme(roomType))
            {
                return roomTypeLabelColor;
            }

            Color baseLabelColor = UsesChallengeBaselineTheme() ? challengeBaselineLabelColor : roomTypeLabelColor;
            Color accentTarget = Color.Lerp(ResolveChallengeThreatThemeAccent(), Color.white, 0.3f);
            float themeStrength = ChallengeThreatPresentationResolver.ResolveStatusThemeStrength(_challengeThreatStage);
            float blend = Mathf.Clamp01(0.12f + (0.16f * themeStrength));
            return Color.Lerp(baseLabelColor, accentTarget, blend);
        }

        private Color ResolveChallengeThemeBadgeColor(Color challengeThemeAccent, float badgeBlend)
        {
            Color baseColor = UsesChallengeBaselineTheme() ? challengeBaselineBadgeColor : challengeThreatBadgeColor;
            return Color.Lerp(baseColor, challengeThemeAccent, badgeBlend);
        }

        private Color ResolveChallengeThemeStatusCardColor(Color challengeThemeAccent, float statusBlend)
        {
            Color baseColor = UsesChallengeBaselineTheme() ? challengeBaselineStatusCardColor : challengeThreatStatusCardColor;
            return Color.Lerp(baseColor, challengeThemeAccent, statusBlend);
        }

        private Color ResolveChallengeThemeDetailCardColor(Color challengeThemeAccent, float detailBlend)
        {
            Color baseColor = UsesChallengeBaselineTheme() ? challengeBaselineDetailCardColor : challengeThreatDetailCardColor;
            return Color.Lerp(baseColor, challengeThemeAccent, detailBlend);
        }

        private Color ResolveChallengeThemeDetailTextColor(Color challengeThemeAccent, float detailTextBlend)
        {
            Color baseColor = UsesChallengeBaselineTheme() ? challengeBaselineDetailTextColor : challengeThreatDetailTextColor;
            return Color.Lerp(baseColor, Color.Lerp(challengeThemeAccent, Color.white, 0.4f), detailTextBlend);
        }

        private void SetStatusEmphasis(bool active, Color accentColor)
        {
            _statusEmphasisActive = active;
            _statusEmphasisAccentColor = accentColor;
            _statusEmphasisPulseFrequencyScale = ResolveStatusEmphasisPulseFrequencyScale();
            _statusEmphasisPulseAmplitudeScale = ResolveStatusEmphasisPulseAmplitudeScale();

            if (!_statusEmphasisActive)
            {
                ResetStatusEmphasisVisuals();
                return;
            }

            ApplyStatusEmphasisVisuals(0f, _topBarLayoutActive ? topBarStatusEmphasisDamping : 1f);
        }

        private void ResetStatusEmphasisVisuals()
        {
            if (roomTypeBadgeImage != null)
            {
                roomTypeBadgeImage.color = _baseRoomTypeBadgeColor;
            }

            if (roomStatusCardImage != null)
            {
                roomStatusCardImage.color = _baseRoomStatusCardColor;
            }

            if (roomDetailCardImage != null)
            {
                roomDetailCardImage.color = _baseRoomDetailCardColor;
            }

            if (roomStatusAccentImage != null)
            {
                roomStatusAccentImage.color = _baseRoomStatusAccentColor;
            }

            if (roomDetailAccentImage != null)
            {
                roomDetailAccentImage.color = _baseRoomDetailAccentColor;
            }

            if (roomStatusText != null)
            {
                roomStatusText.color = _baseRoomStatusTextColor;
            }

            if (roomDetailText != null)
            {
                roomDetailText.color = _baseRoomDetailTextColor;
            }

            if (roomTypeIconImage != null)
            {
                roomTypeIconImage.color = _baseRoomTypeIconColor;
            }
        }

        private void ApplyStatusEmphasisVisuals(float pulse, float pulseDamping = 1f)
        {
            float dampedAmplitudeScale = Mathf.Lerp(1f, _statusEmphasisPulseAmplitudeScale, pulseDamping);
            float tintBlend = Mathf.Lerp(0.08f, statusEmphasisTintStrength * dampedAmplitudeScale * pulseDamping, pulse);
            float textBlend = Mathf.Lerp(0.04f, statusEmphasisTextBoost * Mathf.Lerp(1f, 1.14f, dampedAmplitudeScale - 1f) * pulseDamping, pulse);
            Color brightAccent = Color.Lerp(_statusEmphasisAccentColor, Color.white, 0.18f + (0.18f * pulse));

            if (roomTypeBadgeImage != null)
            {
                roomTypeBadgeImage.color = Color.Lerp(_baseRoomTypeBadgeColor, _statusEmphasisAccentColor, tintBlend);
            }

            if (roomStatusCardImage != null)
            {
                roomStatusCardImage.color = Color.Lerp(_baseRoomStatusCardColor, _statusEmphasisAccentColor, tintBlend * 0.48f);
            }

            if (roomDetailCardImage != null)
            {
                roomDetailCardImage.color = Color.Lerp(_baseRoomDetailCardColor, _statusEmphasisAccentColor, tintBlend * 0.28f);
            }

            if (roomStatusAccentImage != null)
            {
                roomStatusAccentImage.color = Color.Lerp(_baseRoomStatusAccentColor, brightAccent, tintBlend * 0.9f);
            }

            if (roomDetailAccentImage != null)
            {
                roomDetailAccentImage.color = Color.Lerp(_baseRoomDetailAccentColor, brightAccent, tintBlend * 0.55f);
            }

            if (roomStatusText != null)
            {
                roomStatusText.color = Color.Lerp(_baseRoomStatusTextColor, brightAccent, textBlend);
            }

            if (roomDetailText != null)
            {
                roomDetailText.color = Color.Lerp(_baseRoomDetailTextColor, Color.white, textBlend * 0.35f);
            }

            if (roomTypeIconImage != null)
            {
                roomTypeIconImage.color = Color.Lerp(_baseRoomTypeIconColor, brightAccent, textBlend);
            }
        }

        private float ResolveStatusEmphasisPulseFrequencyScale()
        {
            if (!ShouldUseChallengeThreatTheme(_currentRoomType))
            {
                return 1f;
            }

            return ChallengeThreatPresentationResolver.ResolveFeedbackPulseFrequencyScale(_challengeThreatBadgeLabel, _challengeThreatStage);
        }

        private float ResolveStatusEmphasisPulseAmplitudeScale()
        {
            if (!ShouldUseChallengeThreatTheme(_currentRoomType))
            {
                return 1f;
            }

            return ChallengeThreatPresentationResolver.ResolveFeedbackPulseAmplitudeScale(_challengeThreatBadgeLabel, _challengeThreatStage);
        }

        private string BuildStatusHeadlineMarkup(string eyebrow, string headline)
        {
            int eyebrowFontSize = ResolveRoomStatusEyebrowFontSize();
            return
                $"<size={eyebrowFontSize}><color=#{ColorUtility.ToHtmlStringRGBA(roomStatusLabelColor)}><b>{eyebrow}</b></color></size>\n" +
                $"<size={roomStatusFontSize}><b>{headline}</b></size>";
        }

        private string BuildStatusHeadlineMarkup(string eyebrow, string headline, Color eyebrowColor)
        {
            int eyebrowFontSize = ResolveRoomStatusEyebrowFontSize();
            return
                $"<size={eyebrowFontSize}><color=#{ColorUtility.ToHtmlStringRGBA(eyebrowColor)}><b>{eyebrow}</b></color></size>\n" +
                $"<size={roomStatusFontSize}><b>{headline}</b></size>";
        }

        private string BuildCompactStatusHeadlineMarkup(string headline)
        {
            return $"<size={compactRoomStatusFontSize}><b>{headline}</b></size>";
        }

        private string BuildStatusDetailMarkup(string eyebrow, string detail)
        {
            int eyebrowFontSize = ResolveRoomDetailEyebrowFontSize();
            int detailFontSize = ResolveRoomDetailFontSize();
            return
                $"<size={eyebrowFontSize}><color=#{ColorUtility.ToHtmlStringRGBA(roomStatusLabelColor)}><b>{eyebrow}</b></color></size>\n" +
                $"<size={detailFontSize}>{detail}</size>";
        }

        private string BuildStatusDetailMarkup(string eyebrow, string detail, Color eyebrowColor)
        {
            int eyebrowFontSize = ResolveRoomDetailEyebrowFontSize();
            int detailFontSize = ResolveRoomDetailFontSize();
            return
                $"<size={eyebrowFontSize}><color=#{ColorUtility.ToHtmlStringRGBA(eyebrowColor)}><b>{eyebrow}</b></color></size>\n" +
                $"<size={detailFontSize}>{detail}</size>";
        }

        private string NormalizeStatusHeadline(string headline)
        {
            string normalizedHeadline = CollapseWhitespace(headline);
            return string.IsNullOrWhiteSpace(normalizedHeadline) ? "현재 방" : normalizedHeadline;
        }

        private string NormalizeStatusDetail(string detail)
        {
            string normalizedDetail = CollapseWhitespace(detail);
            if (string.IsNullOrWhiteSpace(normalizedDetail))
            {
                return string.Empty;
            }

            if (normalizedDetail.Length <= roomDetailMaxCharacters)
            {
                return normalizedDetail;
            }

            return normalizedDetail.Substring(0, Mathf.Max(1, roomDetailMaxCharacters - 1)).TrimEnd() + "…";
        }

        private string NormalizeCompactStatusHeadline(string headline)
        {
            string normalizedHeadline = CollapseWhitespace(headline);
            if (string.IsNullOrWhiteSpace(normalizedHeadline))
            {
                return "현재 방";
            }

            if (normalizedHeadline.Length <= compactRoomStatusMaxCharacters)
            {
                return normalizedHeadline;
            }

            return normalizedHeadline.Substring(0, Mathf.Max(1, compactRoomStatusMaxCharacters - 1)).TrimEnd() + "…";
        }

        private string ResolveStatusEyebrow(RoomType roomType, string headline, bool emphasize)
        {
            if (ShouldSuppressCompactChallengeAuxiliaryCopy())
            {
                return string.Empty;
            }

            if (roomType == RoomType.Curse && headline.Contains("경고"))
            {
                return "입장 경고";
            }

            if (roomType == RoomType.Curse && emphasize)
            {
                return "저주 보상";
            }

            if (roomType == RoomType.Secret && emphasize)
            {
                return "비밀 신호";
            }

            if (!string.IsNullOrWhiteSpace(_explicitRoomStatusEyebrow))
            {
                return _explicitRoomStatusEyebrow;
            }

            if (roomType == RoomType.Challenge && !string.IsNullOrWhiteSpace(_explicitRoomStatusBadgeLabel))
            {
                return _explicitRoomStatusBadgeLabel;
            }

            if (roomType == RoomType.Challenge && emphasize)
            {
                return "도전 현황";
            }

            if (ShouldUseChallengeThreatTheme(roomType))
            {
                return string.IsNullOrWhiteSpace(_challengeThreatStatusEyebrow)
                    ? ResolveRoomTypeBadgeLabel(roomType)
                    : _challengeThreatStatusEyebrow;
            }

            if (roomType == RoomType.Boss)
            {
                return "위협 분석";
            }

            return "현재 위치";
        }

        private void ApplyDynamicBadgeLayout(string label, bool hasIcon)
        {
            if (roomTypeBadgeImage == null || roomTypeLabelText == null)
            {
                return;
            }

            float minWidth = _compactMode ? compactRoomTypeBadgeMinWidth : roomTypeBadgeMinWidth;
            float maxWidth = _compactMode ? compactRoomTypeBadgeMaxWidth : roomTypeBadgeMaxWidth;
            float characterWidth = _compactMode ? compactRoomTypeBadgeCharacterWidth : roomTypeBadgeCharacterWidth;
            Vector2 badgeSize = _compactMode ? compactRoomTypeBadgeSize : roomTypeBadgeSize;
            Vector2 labelSize = _compactMode ? compactRoomTypeLabelSize : roomTypeLabelSize;
            float computedWidth = minWidth + (Mathf.Max(0, label != null ? label.Length : 0) * characterWidth);
            computedWidth += hasIcon ? 18f : 0f;
            float clampedWidth = Mathf.Clamp(computedWidth, minWidth, maxWidth);

            roomTypeBadgeImage.rectTransform.sizeDelta = new Vector2(clampedWidth, badgeSize.y);
            roomTypeLabelText.rectTransform.sizeDelta = new Vector2(clampedWidth - (hasIcon ? 42f : 28f), labelSize.y);
        }

        private void ApplyPlaceholderStatusPresentation()
        {
            bool showTopBarStatusCards = !(_topBarLayoutActive && hideStatusCardsInTopBar);

            if (roomStatusText != null)
            {
                roomStatusText.supportRichText = true;
                roomStatusText.lineSpacing = ResolveRoomStatusLineSpacing();
                roomStatusText.text = _compactMode
                    ? BuildCompactStatusHeadlineMarkup("현재 방")
                    : BuildStatusHeadlineMarkup("현재 위치", "현재 방");
                roomStatusText.color = placeholderTextColor;
                roomStatusText.gameObject.SetActive(!_compactMode && showTopBarStatusCards);
            }

            if (roomDetailText != null)
            {
                roomDetailText.supportRichText = true;
                roomDetailText.lineSpacing = ResolveRoomDetailLineSpacing();
                roomDetailText.text = BuildStatusDetailMarkup("대기 중", "던전이 생성되면 탐험 정보가 여기에 표시됩니다.");
                roomDetailText.color = roomDetailColor;
                roomDetailText.gameObject.SetActive(!_compactMode && showTopBarStatusCards);
            }

            ApplyStatusCardVisibility(!_compactMode && showTopBarStatusCards, !_compactMode && showTopBarStatusCards);
            ApplyRoomTypeBadge(RoomType.Normal, placeholderTextColor, false);
            SetStatusEmphasis(false, placeholderTextColor);
        }

        private void ApplyCurrentStatusPresentation(bool useCurseAlertTheme, bool useCurseAltarReadyTheme, bool useChallengeThreatTheme)
        {
            bool showTopBarStatusCards = !(_topBarLayoutActive && hideStatusCardsInTopBar);
            bool suppressCompactChallengeAuxiliaryCopy = ShouldSuppressCompactChallengeAuxiliaryCopy();

            if (roomStatusText != null)
            {
                string eyebrow = ResolveStatusEyebrow(_currentRoomType, _currentHeadline, _currentStatusEmphasize);
                Color eyebrowColor = ResolveStatusEyebrowColor(useChallengeThreatTheme);
                roomStatusText.supportRichText = true;
                roomStatusText.lineSpacing = ResolveRoomStatusLineSpacing();
                roomStatusText.text = _compactMode
                    ? useChallengeThreatTheme
                        ? BuildCompactChallengeThreatHeadlineMarkup(_currentHeadline, _challengeThreatCompactTag, ResolveCompactChallengeThreatTagColor())
                        : !string.IsNullOrWhiteSpace(_explicitRoomStatusCompactTag)
                            ? BuildCompactChallengeThreatHeadlineMarkup(
                                ResolveCompactExplicitStatusHeadline(_currentHeadline),
                                _explicitRoomStatusCompactTag,
                                ResolveCompactExplicitStatusTagColor())
                        : BuildCompactStatusHeadlineMarkup(NormalizeCompactStatusHeadline(_currentHeadline))
                    : BuildStatusHeadlineMarkup(eyebrow, _currentHeadline, eyebrowColor);
                roomStatusText.color = _currentAccentColor;
                roomStatusText.gameObject.SetActive(showTopBarStatusCards);
            }

            if (roomDetailText != null)
            {
                string detailEyebrow = useChallengeThreatTheme && !string.IsNullOrWhiteSpace(_challengeThreatDetailEyebrow)
                    ? _challengeThreatDetailEyebrow
                    : "전술 메모";
                if (!useChallengeThreatTheme && !string.IsNullOrWhiteSpace(_explicitRoomStatusDetailEyebrow))
                {
                    detailEyebrow = _explicitRoomStatusDetailEyebrow;
                }

                Color detailEyebrowColor = ResolveDetailEyebrowColor(useChallengeThreatTheme);
                roomDetailText.supportRichText = true;
                roomDetailText.lineSpacing = ResolveRoomDetailLineSpacing();
                roomDetailText.text = suppressCompactChallengeAuxiliaryCopy || string.IsNullOrWhiteSpace(_currentDetail)
                    ? string.Empty
                    : BuildStatusDetailMarkup(detailEyebrow, _currentDetail, detailEyebrowColor);
                roomDetailText.color = useCurseAlertTheme
                    ? curseAlertDetailTextColor
                    : useCurseAltarReadyTheme
                        ? curseAltarReadyDetailTextColor
                        : useChallengeThreatTheme
                            ? challengeThreatDetailTextColor
                            : roomDetailColor;
                roomDetailText.gameObject.SetActive(showTopBarStatusCards && !_compactMode && !suppressCompactChallengeAuxiliaryCopy && !string.IsNullOrWhiteSpace(_currentDetail));
            }

            ApplyStatusCardVisibility(showTopBarStatusCards, showTopBarStatusCards && !_compactMode && roomDetailText != null && roomDetailText.gameObject.activeSelf);
            ApplyRoomTypeBadge(_currentRoomType, _currentAccentColor, true);
        }

        private string BuildCompactChallengeThreatHeadlineMarkup(string headline, string compactTag)
        {
            return BuildCompactChallengeThreatHeadlineMarkup(headline, compactTag, Color.Lerp(_currentAccentColor, Color.white, 0.22f));
        }

        private string BuildCompactChallengeThreatHeadlineMarkup(string headline, string compactTag, Color compactTagColor)
        {
            string normalizedHeadline = NormalizeCompactStatusHeadline(headline);
            string normalizedTag = CollapseWhitespace(compactTag);
            if (string.IsNullOrWhiteSpace(normalizedTag))
            {
                return BuildCompactStatusHeadlineMarkup(NormalizeCompactStatusHeadline(normalizedHeadline));
            }

            int primaryCharacterBudget = Mathf.Max(8, compactRoomStatusMaxCharacters - 6);
            string primary = normalizedHeadline;
            if (primary.Length > primaryCharacterBudget)
            {
                primary = primary.Substring(0, primaryCharacterBudget - 1).TrimEnd() + "…";
            }

            if (normalizedTag.Length > 9)
            {
                normalizedTag = normalizedTag.Substring(0, 8).TrimEnd() + "…";
            }

            int tagFontSize = ResolveCompactChallengeTagFontSize();
            string tagColor = ColorUtility.ToHtmlStringRGBA(compactTagColor);
            return
                $"<size={compactRoomStatusFontSize}><b>{primary}</b></size> " +
                $"<size={tagFontSize}><color=#{tagColor}><b>{normalizedTag}</b></color></size>";
        }

        private string ResolveCompactExplicitStatusHeadline(string headline)
        {
            if (_currentRoomType != RoomType.Challenge || string.IsNullOrWhiteSpace(_explicitRoomStatusCompactTag))
            {
                return NormalizeCompactStatusHeadline(headline);
            }

            if (IsChallengeRewardReadyStatus())
            {
                return IsChallengeFinaleStatus()
                    ? headline.Contains("\uC644\uC804 \uC81C\uC555")
                        ? "\uC644\uC804 \uC81C\uC555"
                        : "\uCD5C\uC885 \uC815\uB9AC"
                    : "\uBCF4\uC0C1 \uAC1C\uBC29";
            }

            if (IsChallengeCompletedStatus())
            {
                return IsChallengeFinaleStatus()
                    ? headline.Contains("\uC644\uC804 \uC81C\uC555")
                        ? "\uC81C\uC555 \uC644\uB8CC"
                        : "\uC815\uB9AC \uC644\uB8CC"
                    : "\uBCF4\uC0C1 \uD68C\uC218";
            }

            return NormalizeCompactStatusHeadline(headline);
        }

        private Color ResolveCompactExplicitStatusTagColor()
        {
            if (_currentRoomType != RoomType.Challenge || string.IsNullOrWhiteSpace(_explicitRoomStatusCompactTag))
            {
                return Color.Lerp(_currentAccentColor, Color.white, 0.22f);
            }

            if (IsChallengeRewardReadyStatus())
            {
                return IsChallengeFinaleStatus()
                    ? challengeFinaleCompactTagColor
                    : challengeRewardReadyCompactTagColor;
            }

            if (IsChallengeCompletedStatus())
            {
                return IsChallengeFinaleStatus()
                    ? challengeFinaleCompactTagColor
                    : challengeCompletedCompactTagColor;
            }

            return Color.Lerp(_currentAccentColor, Color.white, 0.22f);
        }

        private float ResolveRoomStatusLineSpacing()
        {
            ChallengeBannerLayoutProfile layoutProfile = ResolveCurrentChallengeLayoutProfile();
            if (layoutProfile == ChallengeBannerLayoutProfile.None)
            {
                return 1f;
            }

            if (_compactMode)
            {
                return layoutProfile switch
                {
                    ChallengeBannerLayoutProfile.Baseline => challengeBaselineCompactStatusLineSpacing,
                    ChallengeBannerLayoutProfile.Pace => challengePaceCompactStatusLineSpacing,
                    ChallengeBannerLayoutProfile.EliteWarning => eliteWarningCompactStatusLineSpacing,
                    _ => 1f
                };
            }

            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineStatusLineSpacing,
                ChallengeBannerLayoutProfile.Pace => challengePaceStatusLineSpacing,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningStatusLineSpacing,
                _ => 1f
            };
        }

        private float ResolveRoomDetailLineSpacing()
        {
            ChallengeBannerLayoutProfile layoutProfile = ResolveCurrentChallengeLayoutProfile();
            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineDetailLineSpacing,
                ChallengeBannerLayoutProfile.Pace => challengePaceDetailLineSpacing,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningDetailLineSpacing,
                _ => 1.04f
            };
        }

        private ChallengeBannerLayoutProfile ResolveCurrentChallengeLayoutProfile()
        {
            if (_currentRoomType != RoomType.Challenge)
            {
                return ChallengeBannerLayoutProfile.None;
            }

            string resolvedBadgeLabel = !string.IsNullOrWhiteSpace(_explicitRoomStatusBadgeLabel)
                ? _explicitRoomStatusBadgeLabel
                : !string.IsNullOrWhiteSpace(_challengeThreatBadgeLabel)
                    ? _challengeThreatBadgeLabel
                    : "챌린지";

            ChallengeBannerLayoutProfile layoutProfile = ChallengeThreatPresentationResolver.ResolveBannerLayoutProfile(resolvedBadgeLabel);
            return layoutProfile == ChallengeBannerLayoutProfile.None
                ? ChallengeBannerLayoutProfile.Baseline
                : layoutProfile;
        }

        private Vector2 ResolveRoomStatusCardSize(ChallengeBannerLayoutProfile layoutProfile, bool compactMode)
        {
            if (compactMode)
            {
                return layoutProfile switch
                {
                    ChallengeBannerLayoutProfile.Baseline => challengeBaselineCompactRoomStatusCardSize,
                    ChallengeBannerLayoutProfile.Pace => challengePaceCompactRoomStatusCardSize,
                    ChallengeBannerLayoutProfile.EliteWarning => eliteWarningCompactRoomStatusCardSize,
                    _ => compactRoomStatusCardSize
                };
            }

            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineRoomStatusCardSize,
                ChallengeBannerLayoutProfile.Pace => challengePaceRoomStatusCardSize,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningRoomStatusCardSize,
                _ => roomStatusCardSize
            };
        }

        private Vector2 ResolveRoomStatusTextSize(ChallengeBannerLayoutProfile layoutProfile, bool compactMode)
        {
            if (compactMode)
            {
                return layoutProfile switch
                {
                    ChallengeBannerLayoutProfile.Baseline => challengeBaselineCompactRoomStatusTextSize,
                    ChallengeBannerLayoutProfile.Pace => challengePaceCompactRoomStatusTextSize,
                    ChallengeBannerLayoutProfile.EliteWarning => eliteWarningCompactRoomStatusTextSize,
                    _ => compactRoomStatusTextSize
                };
            }

            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineRoomStatusTextSize,
                ChallengeBannerLayoutProfile.Pace => challengePaceRoomStatusTextSize,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningRoomStatusTextSize,
                _ => roomStatusTextSize
            };
        }

        private Vector2 ResolveRoomDetailCardSize(ChallengeBannerLayoutProfile layoutProfile)
        {
            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineRoomDetailCardSize,
                ChallengeBannerLayoutProfile.Pace => challengePaceRoomDetailCardSize,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningRoomDetailCardSize,
                _ => roomDetailCardSize
            };
        }

        private Vector2 ResolveRoomDetailTextSize(ChallengeBannerLayoutProfile layoutProfile)
        {
            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineRoomDetailTextSize,
                ChallengeBannerLayoutProfile.Pace => challengePaceRoomDetailTextSize,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningRoomDetailTextSize,
                _ => roomDetailTextSize
            };
        }

        private float ResolveRoomStatusContentShiftX(ChallengeBannerLayoutProfile layoutProfile, bool compactMode)
        {
            if (compactMode)
            {
                return layoutProfile switch
                {
                    ChallengeBannerLayoutProfile.Baseline => challengeBaselineCompactRoomStatusContentShiftX,
                    ChallengeBannerLayoutProfile.Pace => challengePaceCompactRoomStatusContentShiftX,
                    ChallengeBannerLayoutProfile.EliteWarning => eliteWarningCompactRoomStatusContentShiftX,
                    _ => 0f
                };
            }

            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineRoomStatusContentShiftX,
                ChallengeBannerLayoutProfile.Pace => challengePaceRoomStatusContentShiftX,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningRoomStatusContentShiftX,
                _ => 0f
            };
