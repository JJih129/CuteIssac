        public RectTransform ContentRoot => contentRoot;
        public Color SecretRewardThemeColor => Color.Lerp(secretRewardMarkerColor, secretRewardNodePulseColor, 0.5f);
        public Color CurseAlertThemeColor => Color.Lerp(curseAlertBadgeColor, curseFrameColor, 0.45f);
        public Color CurseAltarRewardThemeColor => Color.Lerp(curseAltarReadyBadgeColor, curseAltarReadyNodePulseColor, 0.52f);
        public float StatusEmphasisPulseSpeed => Mathf.Max(0f, statusEmphasisPulseSpeed);
        public float StatusEmphasisTintStrength => Mathf.Clamp01(statusEmphasisTintStrength);

        public Color GetCurseRewardThemeColor(ItemRarity rarity)
        {
            return rarity switch
            {
                ItemRarity.Rare => curseRareRewardThemeColor,
                ItemRarity.Legendary => curseLegendaryRewardThemeColor,
                ItemRarity.Relic => curseRelicRewardThemeColor,
                ItemRarity.Boss => curseBossRewardThemeColor,
                _ => CurseAltarRewardThemeColor
            };
        }

        private void Update()
        {
            if (_statusEmphasisActive)
            {
                float pulseDamping = _topBarLayoutActive ? topBarStatusEmphasisDamping : 1f;
                float pulseSpeed = Mathf.Max(0f, statusEmphasisPulseSpeed) * Mathf.Lerp(1f, _statusEmphasisPulseFrequencyScale, pulseDamping);
                float pulse = 0.5f + (0.5f * Mathf.Sin(Time.unscaledTime * pulseSpeed));
                ApplyStatusEmphasisVisuals(pulse, pulseDamping);
            }

            if (_challengeThreatTransitionFlashExpiresAt > 0f && Time.unscaledTime >= _challengeThreatTransitionFlashExpiresAt)
            {
                _challengeThreatTransitionFlashExpiresAt = 0f;
                RefreshRenderedRooms();
            }
        }

        public void ConfigureDebugView(Text placeholder, RectTransform minimapContent = null)
        {
            placeholderText = placeholder;
            contentRoot = minimapContent;
            panelRoot = placeholder != null && placeholder.transform.parent != null
                ? placeholder.transform.parent.gameObject
                : panelRoot;
        }

        public void ShowPlaceholder()
        {
            EnsureStatusLabels();
            EnsureViewportHierarchy();
            _currentRoomType = RoomType.Normal;
            _currentHeadline = "현재 방";
            _currentDetail = "던전이 생성되면 탐험 정보가 여기에 표시됩니다.";
            _currentAccentColor = placeholderTextColor;
            _currentStatusEmphasize = false;
            _explicitRoomStatusBadgeLabel = string.Empty;
            _explicitRoomStatusEyebrow = string.Empty;
            _explicitRoomStatusCompactTag = string.Empty;
            _explicitRoomStatusDetailEyebrow = string.Empty;
            _currentHeadline = string.Empty;
            _currentDetail = string.Empty;

            if (placeholderText != null)
            {
                placeholderText.gameObject.SetActive(true);
                placeholderText.text = _compactMode ? string.Empty : "MAP READY";
                placeholderText.color = placeholderTextColor;
                bool showPlaceholder = !_compactMode;
                placeholderText.gameObject.SetActive(showPlaceholder);
                placeholderText.text = showPlaceholder ? "MAP READY" : string.Empty;
            }
            ApplyPlaceholderStatusPresentation();

            HideUnusedNodes(0);
            ApplyPanelVisibility();
        }

        public void SetRoomStatus(RoomType roomType, string headline, string detail, Color accentColor, bool emphasize = false, string explicitBadgeLabel = null, string explicitStatusEyebrow = null, string explicitCompactTag = null, string explicitDetailEyebrow = null)
        {
            EnsureStatusLabels();
            bool useCurseAlertTheme = emphasize && roomType == RoomType.Curse;
            bool useCurseAltarReadyTheme = emphasize && ShouldUseCurseAltarReadyTheme(roomType, headline);
            Color resolvedAccentColor = useCurseAlertTheme
                ? CurseAlertThemeColor
                : useCurseAltarReadyTheme
                    ? CurseAltarRewardThemeColor
                    : accentColor;
            _currentRoomType = roomType;
            _currentHeadline = NormalizeStatusHeadline(headline);
            _currentDetail = NormalizeStatusDetail(detail);
            _currentAccentColor = resolvedAccentColor;
            _currentStatusEmphasize = emphasize;
            _explicitRoomStatusBadgeLabel = string.IsNullOrWhiteSpace(explicitBadgeLabel)
                ? string.Empty
                : CollapseWhitespace(explicitBadgeLabel);
            _explicitRoomStatusEyebrow = string.IsNullOrWhiteSpace(explicitStatusEyebrow)
                ? string.Empty
                : CollapseWhitespace(explicitStatusEyebrow);
            _explicitRoomStatusCompactTag = string.IsNullOrWhiteSpace(explicitCompactTag)
                ? string.Empty
                : CollapseWhitespace(explicitCompactTag);
            _explicitRoomStatusDetailEyebrow = string.IsNullOrWhiteSpace(explicitDetailEyebrow)
                ? string.Empty
                : CollapseWhitespace(explicitDetailEyebrow);

            RefreshCurrentStatusVisualState();
        }

        public void SetCompactMode(bool compactMode)
        {
            _compactMode = compactMode;
            ApplyTopBarLayout(compactMode);
            RefreshCurrentStatusVisualState();
            if (placeholderText != null)
            {
                placeholderText.gameObject.SetActive(false);
            }

            if (placeholderText != null && placeholderText.gameObject.activeSelf)
            {
                placeholderText.text = compactMode ? string.Empty : "MAP READY";
            }
        }

        public void SetChallengeThreatStatusTheme(bool active, Color accentColor, string badgeLabel, string statusEyebrow, string detailEyebrow, string compactTag, ChallengeThreatStage stage)
        {
            Color resolvedAccentColor = active ? accentColor : Color.white;
            string resolvedBadgeLabel = active ? badgeLabel ?? string.Empty : string.Empty;
            string resolvedStatusEyebrow = active ? statusEyebrow ?? string.Empty : string.Empty;
            string resolvedDetailEyebrow = active ? detailEyebrow ?? string.Empty : string.Empty;
            string resolvedCompactTag = active ? compactTag ?? string.Empty : string.Empty;
            ChallengeThreatStage resolvedStage = active ? stage : ChallengeThreatStage.Baseline;
            if (_hasChallengeThreatStatusTheme == active
                && (!_hasChallengeThreatStatusTheme
                    || (ColorsApproximatelyEqual(_challengeThreatStatusAccentColor, resolvedAccentColor)
                        && _challengeThreatBadgeLabel == resolvedBadgeLabel
                        && _challengeThreatStatusEyebrow == resolvedStatusEyebrow
                        && _challengeThreatDetailEyebrow == resolvedDetailEyebrow
                        && _challengeThreatCompactTag == resolvedCompactTag
                        && _challengeThreatStage == resolvedStage)))
            {
                return;
            }

            _hasChallengeThreatStatusTheme = active;
            _challengeThreatStatusAccentColor = resolvedAccentColor;
            _challengeThreatBadgeLabel = resolvedBadgeLabel;
            _challengeThreatStatusEyebrow = resolvedStatusEyebrow;
            _challengeThreatDetailEyebrow = resolvedDetailEyebrow;
            _challengeThreatCompactTag = resolvedCompactTag;
            _challengeThreatStage = resolvedStage;

            if (_currentRoomType == RoomType.Challenge)
            {
                RefreshCurrentStatusVisualState();
            }
        }

        public void ApplyTopBarLayout(bool compactMode)
        {
            _topBarLayoutActive = true;
            CacheDefaultLayoutValues();

            RectTransform rootRect = panelRoot != null
                ? panelRoot.transform as RectTransform
                : transform as RectTransform;

            if (rootRect == null)
            {
                return;
            }

            EnsureViewportHierarchy();

            if (backgroundImage != null)
            {
                RectTransform backgroundRect = backgroundImage.rectTransform;
                backgroundRect.anchorMin = Vector2.zero;
                backgroundRect.anchorMax = Vector2.one;
                backgroundRect.offsetMin = Vector2.zero;
                backgroundRect.offsetMax = Vector2.zero;
            }

            if (frameImage != null && frameImage != backgroundImage)
            {
                RectTransform frameRect = frameImage.rectTransform;
                frameRect.anchorMin = Vector2.zero;
                frameRect.anchorMax = Vector2.one;
                frameRect.offsetMin = Vector2.zero;
                frameRect.offsetMax = Vector2.zero;
            }

            nodeSpacing = compactMode ? compactNodeSpacing : _defaultNodeSpacing;
            baseNodeSize = compactMode ? compactBaseNodeSize : _defaultBaseNodeSize;
            connectionThickness = compactMode ? compactConnectionThickness : _defaultConnectionThickness;

            if (contentRoot != null)
            {
                contentRoot.anchorMin = new Vector2(0.5f, 0.5f);
                contentRoot.anchorMax = new Vector2(0.5f, 0.5f);
                contentRoot.pivot = new Vector2(0.5f, 0.5f);
                contentRoot.anchoredPosition = Vector2.zero;
                contentRoot.sizeDelta = compactMode ? compactContentSize : _defaultContentSize;
            }

            if (viewportRoot != null)
            {
                viewportRoot.anchorMin = Vector2.zero;
                viewportRoot.anchorMax = Vector2.one;
                viewportRoot.offsetMin = compactMode ? compactViewportOffsetMin : expandedViewportOffsetMin;
                viewportRoot.offsetMax = compactMode ? compactViewportOffsetMax : expandedViewportOffsetMax;
            }

            if (placeholderText != null)
            {
                RectTransform placeholderRect = placeholderText.rectTransform;
                placeholderRect.anchorMin = new Vector2(0.5f, 0.5f);
                placeholderRect.anchorMax = new Vector2(0.5f, 0.5f);
                placeholderRect.pivot = new Vector2(0.5f, 0.5f);
                placeholderRect.anchoredPosition = compactMode ? compactPlaceholderOffset : _defaultPlaceholderOffset;
                placeholderRect.sizeDelta = compactMode ? compactPlaceholderSize : _defaultPlaceholderSize;
                placeholderText.fontSize = compactMode
                    ? Mathf.Max(_defaultPlaceholderFontSize, compactPlaceholderFontSize)
                    : _defaultPlaceholderFontSize;
                placeholderText.alignment = TextAnchor.MiddleCenter;
                placeholderText.color = placeholderTextColor;
            }

            ApplyStatusLayout(compactMode);
        }

        public void RenderRooms(IReadOnlyList<MinimapRoomViewData> roomStates)
        {
            if (!TryEnsureContentRoot())
            {
                return;
            }

            if (roomStates == null || roomStates.Count == 0)
            {
                _lastRenderedRooms.Clear();
                ShowPlaceholder();
                return;
            }

            _lastRenderedRooms.Clear();
            for (int index = 0; index < roomStates.Count; index++)
            {
                _lastRenderedRooms.Add(roomStates[index]);
            }

            EnsureNodeCapacity(roomStates.Count);

            Vector2 currentRoomPosition = Vector2.zero;
            bool hasCurrentRoom = false;

            for (int index = 0; index < roomStates.Count; index++)
            {
                MinimapRoomViewData roomState = roomStates[index];
                MinimapNodeView nodeView = _spawnedNodes[index];
                Vector2 anchoredPosition = new(
                    roomState.GridPosition.X * nodeSpacing.x,
                    roomState.GridPosition.Y * nodeSpacing.y);
                bool visible = !hideHiddenRooms || roomState.ExplorationState != RoomExplorationState.Hidden;

                nodeView.SetAnchoredPosition(anchoredPosition);
                nodeView.SetVisible(visible);

                if (!visible)
                {
                    continue;
                }

                nodeView.Present(BuildPresentation(roomState));

                if (roomState.ExplorationState == RoomExplorationState.Current)
                {
                    currentRoomPosition = anchoredPosition;
                    hasCurrentRoom = true;
                }
            }

            HideUnusedNodes(roomStates.Count);

            if (placeholderText != null)
            {
                placeholderText.gameObject.SetActive(false);
            }

            contentRoot.anchoredPosition = hasCurrentRoom
                ? currentRoomFocusOffset - currentRoomPosition
                : currentRoomFocusOffset;

            ApplyPanelVisibility();
        }

        public void SetChallengeThreatNodeState(bool active, int nextWaveNumber, int guaranteedChampionCount, float championChanceBonus)
        {
            int resolvedWaveNumber = active ? Mathf.Max(0, nextWaveNumber) : 0;
            int resolvedGuaranteedChampionCount = active ? Mathf.Max(0, guaranteedChampionCount) : 0;
            float resolvedChampionChanceBonus = active ? Mathf.Max(0f, championChanceBonus) : 0f;
            bool shouldTriggerTransitionFlash = active
                && _hasChallengeThreatNodeState
                && _challengeThreatWaveNumber > 0
                && resolvedWaveNumber > 0
                && resolvedWaveNumber != _challengeThreatWaveNumber;
            bool stateChanged = _hasChallengeThreatNodeState != active
                || _challengeThreatWaveNumber != resolvedWaveNumber
                || _challengeThreatGuaranteedChampionCount != resolvedGuaranteedChampionCount
                || !Mathf.Approximately(_challengeThreatChampionChanceBonus, resolvedChampionChanceBonus);

            if (!stateChanged)
            {
                return;
            }

            _hasChallengeThreatNodeState = active;
            _challengeThreatWaveNumber = resolvedWaveNumber;
            _challengeThreatGuaranteedChampionCount = resolvedGuaranteedChampionCount;
            _challengeThreatChampionChanceBonus = resolvedChampionChanceBonus;
            _challengeThreatTransitionFlashExpiresAt = shouldTriggerTransitionFlash
                ? Time.unscaledTime + Mathf.Max(0.05f, challengeThreatTransitionFlashDuration)
                : active
                    ? _challengeThreatTransitionFlashExpiresAt
                    : 0f;
            RefreshRenderedRooms();
        }

        private void RefreshCurrentStatusVisualState()
        {
            bool useCurseAlertTheme = _currentStatusEmphasize && _currentRoomType == RoomType.Curse && _currentHeadline.Contains("경고");
            bool useCurseAltarReadyTheme = ShouldUseCurseAltarReadyTheme(_currentRoomType, _currentHeadline);
            bool useChallengeThreatTheme = ShouldUseChallengeThreatTheme(_currentRoomType);
            ApplyCurrentStatusPresentation(useCurseAlertTheme, useCurseAltarReadyTheme, useChallengeThreatTheme);
            ApplySpecialStatusTheme(_currentRoomType, useCurseAlertTheme, useCurseAltarReadyTheme, useChallengeThreatTheme);
            CacheStatusVisualBaseline(_currentAccentColor);
            SetStatusEmphasis(_currentStatusEmphasize, _currentAccentColor);
        }

        public void SetVisible(bool visible)
        {
            _isVisible = visible;
            ApplyPanelVisibility();
        }

        private void CacheDefaultLayoutValues()
        {
            if (_cachedDefaultLayoutValues)
            {
                return;
            }

            _defaultNodeSpacing = nodeSpacing;
            _defaultBaseNodeSize = baseNodeSize;
            _defaultConnectionThickness = connectionThickness;
            _defaultContentSize = contentRoot != null ? contentRoot.sizeDelta : compactContentSize;
            _defaultPlaceholderSize = placeholderText != null ? placeholderText.rectTransform.sizeDelta : compactPlaceholderSize;
            _defaultPlaceholderOffset = placeholderText != null ? placeholderText.rectTransform.anchoredPosition : new Vector2(0f, 14f);
            _defaultPlaceholderFontSize = placeholderText != null ? placeholderText.fontSize : compactPlaceholderFontSize;
            _cachedDefaultLayoutValues = true;
        }

        private bool TryEnsureContentRoot()
        {
            if (contentRoot != null)
            {
                EnsureViewportHierarchy();
                EnsureContentRootLayout();
                EnsureViewportMask();
                return true;
            }

            if (!_warnedMissingContentRoot)
            {
                Debug.LogWarning("MinimapPanelView requires a contentRoot RectTransform to render room nodes.", this);
                _warnedMissingContentRoot = true;
            }

            return false;
        }

        private void EnsureContentRootLayout()
        {
            if (contentRoot == null)
            {
                return;
            }

            contentRoot.anchorMin = new Vector2(0.5f, 0.5f);
            contentRoot.anchorMax = new Vector2(0.5f, 0.5f);
            contentRoot.pivot = new Vector2(0.5f, 0.5f);
        }

        private void EnsureViewportHierarchy()
        {
            RectTransform panelRect = ResolvePanelRect();

            if (panelRect == null)
            {
                return;
            }

            if (viewportRoot == null)
            {
                viewportRoot = CreateViewportRoot(panelRect);
            }
            else if (viewportRoot.parent != panelRect)
            {
                viewportRoot.SetParent(panelRect, false);
            }

            viewportRoot.SetAsFirstSibling();
            ReparentViewportChild(contentRoot);

            if (placeholderText != null)
            {
                ReparentViewportChild(placeholderText.rectTransform);
            }
        }

        private void EnsureViewportMask()
        {
            RectTransform viewportRect = viewportRoot != null ? viewportRoot : ResolvePanelRect();

            if (viewportRect == null)
            {
                return;
            }

            if (viewportRect.GetComponent<RectMask2D>() == null)
            {
                viewportRect.gameObject.AddComponent<RectMask2D>();
            }
        }

        private void EnsureStatusLabels()
        {
            RectTransform rootRect = ResolvePanelRect();

            if (rootRect == null)
            {
                return;
            }

            if (roomTypeLabelText == null)
            {
                roomTypeBadgeImage = CreateStatusCard(
                    "RoomTypeBadge",
                    rootRect,
                    roomTypeBadgePosition,
                    roomTypeBadgeSize,
                    roomTypeBadgeBaseColor);
                roomTypeIconImage = CreateStatusIcon(
                    "RoomTypeIcon",
                    rootRect,
                    roomTypeIconPosition,
                    roomTypeIconSize);
                roomTypeLabelText = CreateStatusText(
                    "RoomTypeLabel",
                    rootRect,
                    roomTypeLabelPosition,
                    roomTypeLabelSize,
                    TextAnchor.MiddleLeft,
                    roomTypeFontSize,
                    FontStyle.Bold);
            }

            if (roomStatusText == null)
            {
                roomStatusCardImage = CreateStatusCard(
                    "RoomStatusCard",
                    rootRect,
                    roomStatusCardPosition,
                    roomStatusCardSize,
                    roomStatusCardColor);
                roomStatusAccentImage = CreateStatusCard(
                    "RoomStatusAccent",
                    rootRect,
                    roomStatusAccentPosition,
                    roomStatusAccentSize,
                    new Color(1f, 1f, 1f, accentRailOpacity));
                roomStatusText = CreateStatusText(
                    "RoomStatus",
                    rootRect,
                    roomStatusTextPosition,
                    roomStatusTextSize,
                    TextAnchor.UpperLeft,
                    roomStatusFontSize,
                    FontStyle.Bold);
            }

            if (roomDetailText == null)
            {
                roomDetailCardImage = CreateStatusCard(
                    "RoomDetailCard",
                    rootRect,
                    roomDetailCardPosition,
                    roomDetailCardSize,
                    roomDetailCardColor);
                roomDetailAccentImage = CreateStatusCard(
                    "RoomDetailAccent",
                    rootRect,
                    roomDetailAccentPosition,
                    roomDetailAccentSize,
                    new Color(1f, 1f, 1f, accentRailOpacity * 0.8f));
                roomDetailText = CreateStatusText(
                    "RoomDetail",
                    rootRect,
                    roomDetailTextPosition,
                    roomDetailTextSize,
                    TextAnchor.UpperLeft,
                    roomDetailFontSize,
                    FontStyle.Normal);
                roomDetailText.color = roomDetailColor;
            }

            if (roomTypeBadgeImage != null)
            {
                roomTypeBadgeImage.color = roomTypeBadgeBaseColor;
            }

            if (roomTypeLabelText != null)
            {
                roomTypeLabelText.supportRichText = true;
                roomTypeLabelText.color = roomTypeLabelColor;
            }

            if (roomStatusCardImage != null)
            {
                roomStatusCardImage.color = roomStatusCardColor;
            }

            if (roomStatusAccentImage != null)
            {
                roomStatusAccentImage.color = new Color(1f, 1f, 1f, accentRailOpacity);
            }

            if (roomDetailCardImage != null)
            {
                roomDetailCardImage.color = roomDetailCardColor;
            }

            if (roomDetailAccentImage != null)
            {
                roomDetailAccentImage.color = new Color(1f, 1f, 1f, accentRailOpacity * 0.8f);
            }

            ApplyStatusLayout(_compactMode);
        }

        private RectTransform ResolvePanelRect()
        {
            if (panelRoot == null)
            {
                panelRoot = gameObject;
            }

            if (panelRoot != null && panelRoot.transform is RectTransform panelRect)
            {
                return panelRect;
            }

            return transform as RectTransform;
        }

        private void EnsureNodeCapacity(int requiredCount)
        {
            while (_spawnedNodes.Count < requiredCount)
            {
                _spawnedNodes.Add(CreateNodeInstance(_spawnedNodes.Count));
            }
        }

        private MinimapNodeView CreateNodeInstance(int index)
        {
            if (nodeTemplate != null)
            {
                MinimapNodeView instance = Instantiate(nodeTemplate, contentRoot);
                instance.gameObject.name = $"{nodeTemplate.name}_{index}";
                instance.gameObject.SetActive(true);
                return instance;
            }

            GameObject nodeRoot = new($"MinimapNode_{index}");
            nodeRoot.layer = contentRoot.gameObject.layer;
            RectTransform rootRect = nodeRoot.AddComponent<RectTransform>();
            rootRect.SetParent(contentRoot, false);
            rootRect.anchorMin = new Vector2(0.5f, 0.5f);
            rootRect.anchorMax = new Vector2(0.5f, 0.5f);
            rootRect.pivot = new Vector2(0.5f, 0.5f);
            rootRect.sizeDelta = baseNodeSize;

            Image upConnection = CreateConnectionImage("UpConnection", rootRect, new Vector2(0.5f, 1f), new Vector2(0.5f, 0f));
            Image downConnection = CreateConnectionImage("DownConnection", rootRect, new Vector2(0.5f, 0f), new Vector2(0.5f, 1f));
            Image leftConnection = CreateConnectionImage("LeftConnection", rootRect, new Vector2(0f, 0.5f), new Vector2(1f, 0.5f));
            Image rightConnection = CreateConnectionImage("RightConnection", rootRect, new Vector2(1f, 0.5f), new Vector2(0f, 0.5f));

            Image baseImage = CreateNodeImage("RoomBase", rootRect, Vector2.zero, Vector2.one, new Vector2(0.5f, 0.5f), Vector2.zero, Vector2.zero);
            Image fillImage = CreateNodeImage("RoomFill", rootRect, new Vector2(0.16f, 0.16f), new Vector2(0.84f, 0.84f), new Vector2(0.5f, 0.5f), Vector2.zero, Vector2.zero);
            Image currentMarker = CreateNodeImage("CurrentMarker", rootRect, Vector2.zero, Vector2.one, new Vector2(0.5f, 0.5f), Vector2.zero, Vector2.zero);
            Image specialIcon = CreateNodeImage("SpecialIcon", rootRect, new Vector2(0.5f, 0.5f), new Vector2(0.5f, 0.5f), new Vector2(0.5f, 0.5f), Vector2.zero, baseNodeSize * 0.56f);
            Image clearedMark = CreateNodeImage("ClearedMark", rootRect, new Vector2(1f, 0f), new Vector2(1f, 0f), new Vector2(1f, 0f), Vector2.zero, baseNodeSize * 0.28f);
            clearedMark.rectTransform.anchoredPosition = new Vector2(2f, 2f);
            Image rewardMark = CreateNodeImage("RewardMark", rootRect, new Vector2(0f, 1f), new Vector2(0f, 1f), new Vector2(0f, 1f), Vector2.zero, baseNodeSize * 0.24f);
            rewardMark.rectTransform.anchoredPosition = new Vector2(-2f, -2f);

            MinimapNodeView nodeView = nodeRoot.AddComponent<MinimapNodeView>();
            nodeView.ConfigureFallback(
                rootRect,
                baseImage,
                fillImage,
                currentMarker,
                specialIcon,
                clearedMark,
                rewardMark,
                upConnection,
                downConnection,
                leftConnection,
                rightConnection);
            return nodeView;
        }

        private void HideUnusedNodes(int usedCount)
        {
            for (int index = usedCount; index < _spawnedNodes.Count; index++)
            {
                if (_spawnedNodes[index] != null)
                {
                    _spawnedNodes[index].SetVisible(false);
                }
            }
        }

        private MinimapNodeView.MinimapNodePresentation BuildPresentation(MinimapRoomViewData roomState)
        {
            RoomExplorationState explorationState = roomState.ExplorationState;
            bool isChallengeCompletionNode = roomState.RoomType == RoomType.Challenge
                && roomState.IsCleared
                && roomState.HasCollectedRewardContent;
            Vector2 nodeSize = explorationState == RoomExplorationState.Current
                ? baseNodeSize * 1.18f
                : baseNodeSize;
            float longestSpacing = Mathf.Max(nodeSpacing.x, nodeSpacing.y);
            float longestSize = Mathf.Max(nodeSize.x, nodeSize.y);
            float connectionLength = Mathf.Max(6f, ((longestSpacing - longestSize) * 0.5f) + 2f);
            Sprite rewardSprite = roomState.HasCollectedRewardContent && collectedRewardMarkerSprite != null
                ? collectedRewardMarkerSprite
                : rewardMarkerSprite;
            bool pulseRewardMarker = roomState.RoomType == RoomType.Secret
                && roomState.HasRewardContent
                && !roomState.HasCollectedRewardContent;
            Color resolvedRewardMarkerColor = isChallengeCompletionNode
                ? challengeCompletedRewardMarkerColor
                : roomState.HasCollectedRewardContent
                ? collectedRewardMarkerColor
                : pulseRewardMarker
                    ? secretRewardMarkerColor
                    : rewardMarkerColor;
            bool pulseSecretRewardNode = roomState.RoomType == RoomType.Secret
                && roomState.HasRewardContent
                && !roomState.HasCollectedRewardContent;
            bool pulseCurrentCurseAltarNode = roomState.RoomType == RoomType.Curse
                && roomState.HasRewardContent
                && !roomState.HasCollectedRewardContent
                && explorationState == RoomExplorationState.Current;
            bool pulseCurrentSecretLinkNode = explorationState == RoomExplorationState.Current
                && (roomState.HasUpSecretConnection
                    || roomState.HasDownSecretConnection
                    || roomState.HasLeftSecretConnection
                    || roomState.HasRightSecretConnection);
            bool pulseCurrentChallengeThreatNode = explorationState == RoomExplorationState.Current
                && roomState.RoomType == RoomType.Challenge
                && _hasChallengeThreatNodeState;
            bool pulseChallengeCompletionNode = isChallengeCompletionNode;
            bool pulseNode = pulseSecretRewardNode || pulseCurrentCurseAltarNode || pulseCurrentSecretLinkNode || pulseCurrentChallengeThreatNode || pulseChallengeCompletionNode;
            Color nodePulseColor = pulseSecretRewardNode
                ? secretRewardNodePulseColor
                : pulseCurrentCurseAltarNode
                    ? curseAltarReadyNodePulseColor
                    : pulseCurrentChallengeThreatNode
                        ? ResolveChallengeThreatNodePulseColor()
                        : pulseChallengeCompletionNode
                            ? challengeCompletedNodePulseColor
                        : secretLinkCurrentRoomPulseColor;
            float nodePulseSpeed = pulseSecretRewardNode
                ? secretRewardNodePulseSpeed
                : pulseCurrentCurseAltarNode
                    ? curseAltarReadyNodePulseSpeed
                    : pulseCurrentChallengeThreatNode
                        ? ResolveChallengeThreatNodePulseSpeed()
                        : pulseChallengeCompletionNode
                            ? challengeCompletedNodePulseSpeed
                        : secretLinkNodePulseSpeed;
            float nodePulseTintStrength = pulseSecretRewardNode
                ? secretRewardNodePulseTintStrength
                : pulseCurrentCurseAltarNode
                    ? curseAltarReadyNodePulseTintStrength
                    : pulseCurrentChallengeThreatNode
                        ? ResolveChallengeThreatNodePulseTintStrength()
                        : pulseChallengeCompletionNode
                            ? challengeCompletedNodePulseTintStrength
                        : secretLinkNodePulseTintStrength;
            float nodePulseScaleAmplitude = pulseSecretRewardNode
                ? secretRewardNodePulseScaleAmplitude
                : pulseCurrentCurseAltarNode
                    ? curseAltarReadyNodePulseScaleAmplitude
                    : pulseCurrentChallengeThreatNode
                        ? ResolveChallengeThreatNodePulseScaleAmplitude()
                        : pulseChallengeCompletionNode
                            ? challengeCompletedNodePulseScaleAmplitude
                        : secretLinkNodePulseScaleAmplitude;
            Color resolvedFrameColor = isChallengeCompletionNode
                ? Color.Lerp(challengeFrameColor, challengeCompletedNodePulseColor, 0.34f)
                : GetTypeFrameColor(roomState.RoomType);
            Color resolvedFillColor = isChallengeCompletionNode
                ? Color.Lerp(GetStateFillColor(explorationState), challengeCompletedFillColor, 0.72f)
                : GetStateFillColor(explorationState);
            Color resolvedClearedMarkColor = isChallengeCompletionNode
                ? challengeCompletedClearedMarkerColor
                : clearedMarkerColor;

            return new MinimapNodeView.MinimapNodePresentation(
                nodeSize,
                connectionLength,
                connectionThickness,
                resolvedFrameColor,
                resolvedFillColor,
                pulseNode,
                nodePulseColor,
                nodePulseSpeed,
                nodePulseTintStrength,
                nodePulseScaleAmplitude,
                GetConnectionColor(explorationState),
                secretConnectionColor,
                connectionSprite,
                GetSpecialIcon(roomState.RoomType, explorationState),
                resolvedFrameColor,
                explorationState == RoomExplorationState.Current,
                currentMarkerColor,
                true,
                roomState.IsCleared,
                clearedMarkerSprite,
                resolvedClearedMarkColor,
                roomState.HasRewardContent,
                rewardSprite,
                resolvedRewardMarkerColor,
                pulseRewardMarker,
                roomState.HasUpConnection,
                roomState.HasUpSecretConnection,
                roomState.HasDownConnection,
                roomState.HasDownSecretConnection,
                roomState.HasLeftConnection,
                roomState.HasLeftSecretConnection,
                roomState.HasRightConnection,
                roomState.HasRightSecretConnection);
        }

        private void RefreshRenderedRooms()
        {
            if (_lastRenderedRooms.Count == 0 || !TryEnsureContentRoot())
            {
                return;
            }

            EnsureNodeCapacity(_lastRenderedRooms.Count);

            for (int index = 0; index < _lastRenderedRooms.Count; index++)
            {
                MinimapRoomViewData roomState = _lastRenderedRooms[index];
                MinimapNodeView nodeView = _spawnedNodes[index];
                bool visible = !hideHiddenRooms || roomState.ExplorationState != RoomExplorationState.Hidden;
                nodeView.SetVisible(visible);

                if (!visible)
                {
                    continue;
                }

                nodeView.Present(BuildPresentation(roomState));
            }
        }

        private Color ResolveChallengeThreatNodePulseColor()
        {
            Color themeAccent = ResolveChallengeThreatThemeAccent();
            float nodePulseScale = ResolveChallengeThreatNodePulseScaleFactor();
            Color baseColor = Color.Lerp(
                Color.Lerp(challengeThreatNodePulseColor, themeAccent, 0.58f),
                challengeThreatHeavyNodePulseColor,
                Mathf.Clamp01((_challengeThreatGuaranteedChampionCount >= 2
                    ? 1f
                    : Mathf.InverseLerp(0.08f, 0.22f, _challengeThreatChampionChanceBonus)) * nodePulseScale));
            float flashStrength = EvaluateChallengeThreatTransitionFlashStrength();
            return flashStrength <= 0f
                ? baseColor
                : Color.Lerp(baseColor, challengeThreatTransitionFlashColor, 0.42f * flashStrength);
        }

        private float ResolveChallengeThreatNodePulseSpeed()
        {
            float baseSpeed = challengeThreatNodePulseSpeed
                + (_challengeThreatGuaranteedChampionCount * 0.3f)
                + Mathf.Lerp(0f, 0.22f, Mathf.InverseLerp(0.08f, 0.22f, _challengeThreatChampionChanceBonus));
            baseSpeed *= ResolveChallengeThreatNodePulseScaleFactor();
            return baseSpeed + (challengeThreatTransitionPulseSpeedBonus * EvaluateChallengeThreatTransitionFlashStrength());
        }

        private float ResolveChallengeThreatNodePulseTintStrength()
        {
            float baseTintStrength = Mathf.Clamp(
                challengeThreatNodePulseTintStrength
                + (_challengeThreatGuaranteedChampionCount * 0.03f)
                + Mathf.Lerp(0f, 0.03f, Mathf.InverseLerp(0.08f, 0.22f, _challengeThreatChampionChanceBonus)),
                0f,
                0.35f);
            baseTintStrength = Mathf.Clamp(baseTintStrength * Mathf.Lerp(0.92f, 1.2f, Mathf.InverseLerp(1f, 1.3f, ResolveChallengeThreatNodePulseScaleFactor())), 0f, 0.35f);
            return Mathf.Clamp(
                baseTintStrength + (challengeThreatTransitionPulseTintBoost * EvaluateChallengeThreatTransitionFlashStrength()),
                0f,
                0.35f);
        }

        private float ResolveChallengeThreatNodePulseScaleAmplitude()
        {
            return challengeThreatNodePulseScaleAmplitude
                + (_challengeThreatGuaranteedChampionCount * 0.025f)
                + Mathf.Lerp(0f, 0.02f, Mathf.InverseLerp(0.08f, 0.22f, _challengeThreatChampionChanceBonus))
                + ((ResolveChallengeThreatNodePulseScaleFactor() - 1f) * 0.05f)
                + (challengeThreatTransitionPulseScaleBoost * EvaluateChallengeThreatTransitionFlashStrength());
        }

        private float ResolveChallengeThreatNodePulseScaleFactor()
        {
            return ChallengeThreatPresentationResolver.ResolveNodePulseScale(_challengeThreatStage);
        }

        private float EvaluateChallengeThreatTransitionFlashStrength()
        {
            if (_challengeThreatTransitionFlashExpiresAt <= 0f)
            {
                return 0f;
            }

            float remaining = _challengeThreatTransitionFlashExpiresAt - Time.unscaledTime;
            if (remaining <= 0f)
            {
                return 0f;
            }

            float duration = Mathf.Max(0.05f, challengeThreatTransitionFlashDuration);
            return Mathf.Clamp01(remaining / duration);
        }

        private Color GetStateFillColor(RoomExplorationState explorationState)
        {
            return explorationState switch
            {
                RoomExplorationState.Current => currentFillColor,
                RoomExplorationState.Cleared => clearedFillColor,
                RoomExplorationState.Visited => visitedFillColor,
                RoomExplorationState.Discovered => discoveredFillColor,
                _ => hiddenFillColor
            };
        }

        private Color GetConnectionColor(RoomExplorationState explorationState)
        {
            Color fillColor = GetStateFillColor(explorationState);
            return new Color(fillColor.r, fillColor.g, fillColor.b, Mathf.Max(0.35f, fillColor.a));
        }

        private Color GetTypeFrameColor(RoomType roomType)
        {
            return roomType switch
            {
                RoomType.Start => startFrameColor,
                RoomType.Boss => bossFrameColor,
                RoomType.MiniBoss => miniBossFrameColor,
                RoomType.Treasure => treasureFrameColor,
                RoomType.Shop => shopFrameColor,
                RoomType.Secret => secretFrameColor,
                RoomType.Challenge => challengeFrameColor,
                RoomType.Trap => trapFrameColor,
                RoomType.Curse => curseFrameColor,
                _ => normalFrameColor
            };
        }

        private Sprite GetSpecialIcon(RoomType roomType, RoomExplorationState explorationState)
        {
            if (explorationState == RoomExplorationState.Hidden)
            {
                return null;
            }

            return roomType switch
            {
                RoomType.Start => startRoomIcon,
                RoomType.Boss => bossRoomIcon,
                RoomType.MiniBoss => miniBossRoomIcon != null ? miniBossRoomIcon : bossRoomIcon,
                RoomType.Treasure => treasureRoomIcon,
                RoomType.Shop => shopRoomIcon,
                RoomType.Secret => secretRoomIcon,
                RoomType.Challenge => challengeRoomIcon,
                RoomType.Trap => trapRoomIcon,
                RoomType.Curse => curseRoomIcon != null ? curseRoomIcon : secretRoomIcon,
                _ => null
            };
        }

        private void ApplyPanelVisibility()
        {
            if (panelRoot != null)
            {
                panelRoot.SetActive(_isVisible);
            }
        }

        private static Image CreateConnectionImage(string name, RectTransform parent, Vector2 anchor, Vector2 pivot)
        {
            GameObject imageObject = new(name, typeof(RectTransform), typeof(CanvasRenderer), typeof(Image));
            imageObject.transform.SetParent(parent, false);
            RectTransform rectTransform = imageObject.GetComponent<RectTransform>();
            rectTransform.anchorMin = anchor;
            rectTransform.anchorMax = anchor;
            rectTransform.pivot = pivot;

            Image image = imageObject.GetComponent<Image>();
            image.raycastTarget = false;
            image.gameObject.SetActive(false);
            return image;
        }

        private static Image CreateNodeImage(
            string name,
            RectTransform parent,
            Vector2 anchorMin,
            Vector2 anchorMax,
            Vector2 pivot,
            Vector2 anchoredPosition,
            Vector2 sizeDelta)
        {
            GameObject imageObject = new(name, typeof(RectTransform), typeof(CanvasRenderer), typeof(Image));
            imageObject.transform.SetParent(parent, false);
            RectTransform rectTransform = imageObject.GetComponent<RectTransform>();
            rectTransform.anchorMin = anchorMin;
            rectTransform.anchorMax = anchorMax;
            rectTransform.pivot = pivot;
            rectTransform.anchoredPosition = anchoredPosition;
            rectTransform.sizeDelta = sizeDelta;

            Image image = imageObject.GetComponent<Image>();
            image.raycastTarget = false;
            return image;
        }

        private static Text CreateStatusText(
            string name,
            RectTransform parent,
            Vector2 anchoredPosition,
            Vector2 size,
            TextAnchor anchor,
            int fontSize,
            FontStyle style)
        {
            GameObject textObject = new(name, typeof(RectTransform), typeof(CanvasRenderer), typeof(Text));
            textObject.transform.SetParent(parent, false);
            RectTransform rectTransform = textObject.GetComponent<RectTransform>();
            rectTransform.anchorMin = new Vector2(0f, 1f);
            rectTransform.anchorMax = new Vector2(0f, 1f);
            rectTransform.pivot = new Vector2(0f, 1f);
            rectTransform.anchoredPosition = anchoredPosition;
            rectTransform.sizeDelta = size;

            Text text = textObject.GetComponent<Text>();
            LocalizedUiFontProvider.Apply(text);
            text.fontSize = fontSize;
            text.fontStyle = style;
            text.alignment = anchor;
            text.color = Color.white;
            text.raycastTarget = false;
            return text;
        }

        private static Image CreateStatusCard(
            string name,
            RectTransform parent,
            Vector2 anchoredPosition,
            Vector2 size,
            Color color)
        {
            GameObject imageObject = new(name, typeof(RectTransform), typeof(CanvasRenderer), typeof(Image));
            imageObject.transform.SetParent(parent, false);
            RectTransform rectTransform = imageObject.GetComponent<RectTransform>();
