        private int ResolveCompactChallengeTagFontSize()
        {
            ChallengeBannerLayoutProfile layoutProfile = ResolveCurrentChallengeLayoutProfile();
            return layoutProfile switch
            {
                ChallengeBannerLayoutProfile.Baseline => challengeBaselineCompactTagFontSize,
                ChallengeBannerLayoutProfile.Pace => challengePaceCompactTagFontSize,
                ChallengeBannerLayoutProfile.EliteWarning => eliteWarningCompactTagFontSize,
                _ => Mathf.Max(10, compactRoomStatusFontSize - 2)
            };
        }

        private static string CollapseWhitespace(string value)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                return string.Empty;
            }

            string[] segments = value.Split((char[])null, System.StringSplitOptions.RemoveEmptyEntries);
            return string.Join(" ", segments);
        }

        private static string GetRoomTypeLabel(RoomType roomType)
        {
            return roomType switch
            {
                RoomType.Start => "시작 방",
                RoomType.Boss => "보스 방",
                RoomType.MiniBoss => "미니보스",
                RoomType.Treasure => "보물 방",
                RoomType.Shop => "상점",
                RoomType.Secret => "비밀 방",
                RoomType.Challenge => "도전 방",
                RoomType.Trap => "함정 방",
                RoomType.Curse => "저주 방",
                _ => "일반 방"
            };
        }

        private static bool ColorsApproximatelyEqual(Color lhs, Color rhs)
        {
            return Mathf.Approximately(lhs.r, rhs.r)
                && Mathf.Approximately(lhs.g, rhs.g)
                && Mathf.Approximately(lhs.b, rhs.b)
                && Mathf.Approximately(lhs.a, rhs.a);
        }
    }
}
